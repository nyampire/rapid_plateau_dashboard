# Environment for the weekly batch (systemd EnvironmentFile).
# Copy to a secured location referenced by the .service (e.g.
# /etc/rapid-plateau-dashboard.env), `chmod 600`, and fill in real values.
# DO NOT commit the filled-in copy — it contains the DB password.

# Required: PostgreSQL connection string (the dashboard writes dash_* only).
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DBNAME

# Repo root (matches WorkingDirectory in the .service).
DASH_HOME=/opt/rapid_plateau_dashboard

# Optional: a venv to activate so python3 has psycopg2 (and friends) available.
DASH_VENV=/opt/rapid_plateau_dashboard/.venv

# Optional: refresh the national city master each run (Phase 0). Omit to skip.
DASH_CSV=/opt/rapid_plateau_dashboard/data/plateau_city_master_2025.csv

# Optional: limit to specific Geofabrik regions (space-separated). Default: all 8.
# DASH_REGIONS=shikoku kyushu
